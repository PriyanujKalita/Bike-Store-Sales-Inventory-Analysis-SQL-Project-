-- Finding total revenue generated by each store
select * from stores; 
select * from orders; 
select * from order_items;

select
	stores.store_name,
    sum(order_items.quantity * order_items.list_price * (1 - order_items.discount)) as total_revenue
from order_items
join orders
    on orders.order_id = order_items.order_id
join stores
    on stores.store_id = orders.store_id
group by stores.store_name;

-- Top 5 most sold products by quantity
select * from products;
select * from order_items;

SELECT 
    products.product_name,
    SUM(order_items.quantity) AS total_quantity_sold
FROM order_items 
JOIN products  
    ON order_items.product_id = products.product_id
GROUP BY products.product_name
ORDER BY total_quantity_sold DESC
LIMIT 5;

-- Customers who placed orders with store names.
select * from customers;
select * from orders;
select * from stores;

SELECT 
    customers.first_name,
    customers.last_name,
    stores.store_name
FROM customers
JOIN orders 
    ON customers.customer_id = orders.customer_id
JOIN stores 
    ON orders.store_id = stores.store_id;
    
    
-- Total number of products per brand.
select * from brands;
select * from products;
    
SELECT 
    brands.brand_name,
    count(products.brand_id) AS number_of_product
FROM products 
JOIN brands  
    ON products.brand_id = brands.brand_id
GROUP BY brands.brand_name;

-- Products with zero quantity in stock.
select * from stocks;
select * from products;
    
select product_id from stocks where quantity = 0; 

select
	products.product_name,
    stocks.product_id
from stocks
inner join products
     on products.product_id = stocks.product_id
where stocks.quantity = 0;
